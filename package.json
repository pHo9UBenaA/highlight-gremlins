{
  "name": "highlight-unwanted-spaces",
  "displayName": "Highlight Unwanted Spaces",
  "description": "Highlight and remove full-width spaces, trailing spaces, and gremlin characters",
  "version": "0.0.4",
  "publisher": "ryohei-hashimoto",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryohei-hashimoto/highlight-unwanted-spaces"
  },
  "keywords": [
    "spaces",
    "whitespace",
    "fullwidth",
    "trailing",
    "gremlins",
    "highlight",
    "unicode"
  ],
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "highlight-unwanted-spaces.convertFullwidthSpaces",
        "title": "Highlight Unwanted Spaces: Convert Full-width Spaces to Half-width"
      },
      {
        "command": "highlight-unwanted-spaces.removeTrailingSpaces",
        "title": "Highlight Unwanted Spaces: Remove Trailing Spaces"
      },
      {
        "command": "highlight-unwanted-spaces.removeGremlins",
        "title": "Highlight Unwanted Spaces: Clean Up Gremlins"
      },
      {
        "command": "highlight-unwanted-spaces.fixAll",
        "title": "Highlight Unwanted Spaces: Fix All"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Highlight Unwanted Spaces",
      "properties": {
        "highlight-unwanted-spaces.fullwidthSpaces.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable full-width space highlighting"
        },
        "highlight-unwanted-spaces.trailingSpaces.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable trailing space highlighting"
        },
        "highlight-unwanted-spaces.gremlins.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable gremlin character highlighting"
        },
        "highlight-unwanted-spaces.gremlins.characters": {
          "type": "object",
          "description": "List of gremlin characters to detect. Key is hex code point, value has description, level, and optional zeroWidth and replacement fields.",
          "scope": "language-overridable",
          "default": {
            "2013": {
              "description": "en dash",
              "level": "warning",
              "replacement": "-"
            },
            "2018": {
              "description": "left single quotation mark",
              "level": "warning",
              "replacement": "'"
            },
            "2019": {
              "description": "right single quotation mark",
              "level": "warning",
              "replacement": "'"
            },
            "2029": {
              "zeroWidth": true,
              "description": "paragraph separator",
              "level": "error"
            },
            "2066": {
              "zeroWidth": true,
              "description": "Left to right",
              "level": "error"
            },
            "2069": {
              "zeroWidth": true,
              "description": "Pop directional",
              "level": "error"
            },
            "0003": {
              "description": "end of text",
              "level": "warning",
              "replacement": ""
            },
            "000b": {
              "description": "line tabulation",
              "level": "warning",
              "replacement": " "
            },
            "00a0": {
              "description": "non breaking space",
              "level": "info",
              "replacement": " "
            },
            "00ad": {
              "description": "soft hyphen",
              "level": "info"
            },
            "200b": {
              "zeroWidth": true,
              "description": "zero width space",
              "level": "error"
            },
            "200c": {
              "zeroWidth": true,
              "description": "zero width non-joiner",
              "level": "warning",
              "replacement": ""
            },
            "200e": {
              "zeroWidth": true,
              "description": "left-to-right mark",
              "level": "error"
            },
            "201c": {
              "description": "left double quotation mark",
              "level": "warning",
              "replacement": "\""
            },
            "201d": {
              "description": "right double quotation mark",
              "level": "warning",
              "replacement": "\""
            },
            "202c": {
              "zeroWidth": true,
              "description": "pop directional formatting",
              "level": "error"
            },
            "202d": {
              "zeroWidth": true,
              "description": "left-to-right override",
              "level": "error"
            },
            "202e": {
              "zeroWidth": true,
              "description": "right-to-left override",
              "level": "error"
            },
            "fffc": {
              "zeroWidth": true,
              "description": "object replacement character",
              "level": "error"
            }
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npx @vscode/vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "fast-check": "^4.5.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
